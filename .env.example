# Application
APP_NAME=Intelligent Document Processor
APP_ENV=development
DEBUG=True
APP_VERSION=0.1.0
SECRET_KEY=''
# API Settings
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# Security
JWT_SECRET_KEY=''
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=960

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=intelligent_docs
DB_HOST=localhost
DB_PORT=543
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intelligent_docs
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=change_this_password

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,txt,docx,csv,xlsx

# AI/ML Settings
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GEMINI_API_KEY=your-google-ai-studio-key-here   # free at aistudio.google.com/apikey
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4
MAX_TOKENS=4096

# Embedding provider: openai (1536d) | gemini (768d, free tier).
# When switching to gemini: set EMBEDDING_DIM=768 and recreate the Qdrant
# collection (dimensions must match). LLM_MODEL=gemini-2.0-flash for free chat.
EMBEDDING_PROVIDER=openai
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=1536

# Vector Database
VECTOR_DB_PATH=./data/vector_db
VECTOR_COLLECTION_NAME=documents

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Retries
RETRY_MAX_ATTEMPTS=3
RETRY_MIN_BACKOFF_SECONDS=0.5
RETRY_MAX_BACKOFF_SECONDS=8

# CORS (comma-separated origins; use exact scheme+host+port)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_STORAGE_URI=memory://
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_REFRESH=20/minute
RATE_LIMIT_UPLOAD=10/minute
RATE_LIMIT_INGESTION=5/minute
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_CHAT=20/minute

# Qdrant
# - Local (running API on host): http://localhost:6333
# - Docker Compose (running API in container): http://qdrant:6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents
EMBEDDING_DIM=1536
QDRANT_API_KEY=
